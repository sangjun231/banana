{
  "name": "photo-in-my-hand",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter backend start:dev",
    "build": "pnpm --filter frontend build",
    "build:backend": "pnpm --filter backend build",
    "start": "pnpm --filter frontend start",
    "start:backend": "pnpm --filter backend start:prod",
    "lint": "biome lint .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "genTypes": "pnpm --filter frontend genTypes",
    "prepare": "husky",
    "test": "pnpm --filter frontend test",
    "test:unit": "pnpm --filter frontend test:unit",
    "test:integration": "pnpm --filter frontend test:integration",
    "test:backend": "pnpm --filter backend test",
    "test:all": "pnpm --filter frontend test && pnpm --filter frontend test:e2e",
    "test:ui": "pnpm --filter frontend test:ui",
    "test:watch": "pnpm --filter frontend test:watch",
    "coverage": "pnpm --filter frontend coverage",
    "test:e2e": "pnpm --filter frontend test:e2e",
    "test:e2e:ui": "pnpm --filter frontend test:e2e:ui",
    "test:ci": "pnpm --filter frontend test:ci"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.4",
    "husky": "^9.1.7"
  }
}
